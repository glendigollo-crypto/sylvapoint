# ===========================================
# SylvaPoint GTM Audit Tool — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control

# --- Supabase (server) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (browser — same values as above) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Claude API ---
ANTHROPIC_API_KEY=

# --- Firecrawl ---
FIRECRAWL_API_KEY=

# --- Gemini (for /frontend-design skill) ---
GEMINI_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_BASIC=              # Stripe Price ID for $47 basic playbook
STRIPE_PRICE_ID_PREMIUM=            # Stripe Price ID for $97 premium playbook

# --- M-Pesa (Daraja API) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=                 # Full callback URL (e.g. https://your-domain.vercel.app/api/payments/mpesa/callback)

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Admin ---
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=                   # Signs admin JWT tokens (generate: openssl rand -base64 32)

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CAL_LINK=               # Cal.com booking URL (e.g. https://cal.com/yourname/gtm-strategy)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
