# ===========================================
# SylvaPoint GTM Audit Tool — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude API ---
ANTHROPIC_API_KEY=

# --- Firecrawl ---
FIRECRAWL_API_KEY=

# --- Gemini (for /frontend-design skill) ---
GEMINI_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- M-Pesa (Daraja API) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Admin ---
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
